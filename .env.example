# Token del bot, te lo da @BotFather en Telegram
TELEGRAM_BOT_TOKEN=

# API key gratis en https://console.groq.com
GROQ_API_KEY=

# Datos de tu proyecto en supabase.com (Settings > API)
SUPABASE_URL=
SUPABASE_KEY=

# IDs de Telegram de las personas que pueden subir info (separados por coma)
# Para saber tu ID, escribele a @userinfobot en Telegram
ADMIN_IDS=123456789,987654321
